# Folio - environment configuration
#
# Copy this file to `.env.local` and adjust as needed:
#   cp .env.example .env.local
#
# Folio runs entirely in the browser, so every variable that the editor reads
# must be prefixed with NEXT_PUBLIC_ (server-only secrets do not belong here).
# Feature flags below gate work that is incomplete or NOT yet supported; they
# default to "false" so the shipped build only exposes finished features.

# ---- App ----
NEXT_PUBLIC_APP_NAME=Folio
NEXT_PUBLIC_APP_URL=https://folio.ziloris.com

# ---- Supported today (flag lets you hide a feature if a build regresses) ----
# In-place editing of existing text/image objects (move, recolor, resize,
# font swap, delete) and annotation tools. On by default.
NEXT_PUBLIC_FEATURE_CONTENT_EDIT=true

# ---- Not yet supported / experimental (leave false) ----
# Multi-line paragraph reflow of existing text runs (today: single run only).
NEXT_PUBLIC_FEATURE_TEXT_REFLOW=false
# AcroForm form-field detection and filling.
NEXT_PUBLIC_FEATURE_FORM_FIELDS=false
# True redaction: permanently remove content + burn (today: object delete only).
NEXT_PUBLIC_FEATURE_REDACTION=false
# OCR for scanned / image-only PDFs.
NEXT_PUBLIC_FEATURE_OCR=false
# Split / extract selected pages into a separate downloaded PDF.
NEXT_PUBLIC_FEATURE_PAGE_EXTRACT=false
# Set or remove a password (encryption) when exporting.
NEXT_PUBLIC_FEATURE_ENCRYPT_EXPORT=false
# Cryptographic digital signatures (today: drawn/image signatures only).
NEXT_PUBLIC_FEATURE_DIGITAL_SIGNATURE=false
